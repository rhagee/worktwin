#!/usr/bin/env bash
# worktwin-clear - remove a worker's worktree directory and parallel/
# state file. Used to mark a worker complete (after a manual ship via
# /worktwin-finalize) or to drop a stale entry. Safe by default: the
# command refuses if the worktree has uncommitted changes. --force
# overrides.
set -e

usage() {
  cat <<'EOF'
worktwin-clear [--force] <branch>
worktwin-clear --all [--force]

Removes the worktree directory (when present) and the parallel/ state
file for one worker (when a branch is given) or for every active worker
(with --all). The branches themselves are never deleted.

Default behaviour:
  - If the worktree directory is missing (stale state), remove the
    state file silently.
  - If the worktree exists and the working tree is clean, run
    'git worktree remove' and then remove the state file.
  - If the worktree has uncommitted changes, refuse and report.

With --force, the worktree is removed regardless of uncommitted state
('git worktree remove --force') and the state file goes too.

With --all, the same gates apply per-worker: dirty workers are skipped
(or removed when --force is also set). The exit code is 0 even when
some workers are skipped, so the user can re-run with --force after
inspecting the report.
EOF
}

FORCE=0
ALL=0
ARGS=()
for arg in "$@"; do
  case "$arg" in
    -h|--help) usage; exit 0 ;;
    --force) FORCE=1 ;;
    --all) ALL=1 ;;
    *) ARGS+=("$arg") ;;
  esac
done
set -- "${ARGS[@]}"

if [ $ALL -eq 0 ] && [ $# -lt 1 ]; then
  echo "usage: worktwin-clear [--force] <branch>  OR  worktwin-clear --all [--force]" >&2
  exit 2
fi
if [ $ALL -eq 1 ] && [ $# -gt 0 ]; then
  echo "ERROR: do not combine --all with a branch name" >&2
  exit 2
fi

BRANCH="${1:-}"

GIT_COMMON_DIR=$(git rev-parse --git-common-dir 2>/dev/null || true)
if [ -z "$GIT_COMMON_DIR" ]; then
  echo "ERROR: not inside a git repository" >&2
  exit 1
fi
GIT_COMMON_DIR=$(cd "$GIT_COMMON_DIR" && pwd)
PARALLEL_DIR="$GIT_COMMON_DIR/parallel"

# Clear a single worker by state file path.
# Returns 0 on success, 1 if uncommitted and not forced, 2 on other error.
clear_one() {
  local file="$1"
  local branch worktree uncommitted
  branch=$(grep -m1 '"branch":' "$file" | sed -E 's/.*"branch":[[:space:]]*"([^"]*)".*/\1/')
  worktree=$(grep -m1 '"worktree":' "$file" | sed -E 's/.*"worktree":[[:space:]]*"([^"]*)".*/\1/')

  if [ -n "$worktree" ] && [ -d "$worktree" ]; then
    uncommitted=$(git -C "$worktree" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
    if [ "$uncommitted" -gt 0 ] && [ $FORCE -eq 0 ]; then
      echo "SKIP $branch ($worktree has $uncommitted uncommitted change(s))" >&2
      return 1
    fi
    if [ $FORCE -eq 1 ]; then
      git worktree remove --force "$worktree" 2>/dev/null || rm -rf "$worktree"
    else
      git worktree remove "$worktree" 2>/dev/null || true
    fi
    echo "removed worktree: $worktree"
  fi
  rm "$file"
  echo "removed state: $file"
  return 0
}

# After a clear pass, sweep the auto-discovered base worktree: if there
# are no more workers parked under it, remove it. The Dev Drive ends up
# clean when no work is in flight, exactly mirroring the user-visible
# parallel/ state. Only paths under .worktwin-bases are touched - any
# user-configured light base is left alone.
sweep_auto_base() {
  local main_repo base_json base_path workers_left
  main_repo=$(cd "$(dirname "$GIT_COMMON_DIR")" && pwd)
  local tool="$(dirname "$0")/worktwin-light-base"
  [ -x "$tool" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  base_json=$("$tool" get "$main_repo" 2>/dev/null || true)
  [ -n "$base_json" ] || return 0
  base_path=$(printf '%s' "$base_json" | jq -r '.light_base // empty')
  [ -n "$base_path" ] || return 0
  case "$base_path" in
    */.worktwin-bases/*) ;;
    *) return 0 ;;
  esac
  [ -d "$base_path" ] || { "$tool" remove "$main_repo" >/dev/null 2>&1 || true; return 0; }
  workers_left=$(git -C "$main_repo" worktree list --porcelain 2>/dev/null \
    | awk -v base="$base_path" '/^worktree/ { if ($2 != base && index($2, base "--") == 1) c++ } END { print c+0 }')
  if [ "$workers_left" = "0" ]; then
    git -C "$main_repo" worktree remove "$base_path" 2>/dev/null \
      || git -C "$main_repo" worktree remove --force "$base_path" 2>/dev/null \
      || rm -rf "$base_path"
    echo "removed auto base worktree (no workers left): $base_path"
    "$tool" remove "$main_repo" >/dev/null 2>&1 || true
  fi
}

if [ $ALL -eq 1 ]; then
  if [ ! -d "$PARALLEL_DIR" ]; then
    sweep_auto_base
    echo "no active workers"
    exit 0
  fi
  cleared=0
  skipped=0
  for f in "$PARALLEL_DIR"/*.json; do
    [ -f "$f" ] || continue
    if clear_one "$f"; then
      cleared=$((cleared + 1))
    else
      skipped=$((skipped + 1))
    fi
  done
  echo ""
  if [ $skipped -gt 0 ]; then
    echo "summary: $cleared cleared, $skipped skipped (re-run with --force to discard their uncommitted work)"
  else
    echo "summary: $cleared cleared"
  fi
  git worktree prune 2>/dev/null || true
  sweep_auto_base
  exit 0
fi

# Single-branch mode
STATE_FILE=""
if [ -d "$PARALLEL_DIR" ]; then
  for f in "$PARALLEL_DIR"/*.json; do
    [ -f "$f" ] || continue
    if grep -q "\"branch\":[[:space:]]*\"$BRANCH\"" "$f"; then
      STATE_FILE="$f"
      break
    fi
  done
fi

if [ -z "$STATE_FILE" ]; then
  echo "ERROR: no state file found for branch '$BRANCH'" >&2
  exit 1
fi

if ! clear_one "$STATE_FILE"; then
  echo "Commit, stash, or pass --force to discard." >&2
  exit 1
fi

git worktree prune 2>/dev/null || true
sweep_auto_base
